# .husky/commit-msg
first_line="$(head -n1 "$1")"

# Allow auto/maintenance commits that shouldn't be blocked
case "$first_line" in
  "Merge "*|fixup!\ *|squash!\ *|Revert\ *) exit 0 ;;
esac

pattern='^WG-[0-9]+: (feat|refactor|fix|chore|docs|build|ci|perf|style|test|revert) - .+'

if printf '%s\n' "$first_line" | grep -Eq "$pattern"; then
  exit 0
else
  echo "Invalid commit message:"
  echo "   $first_line"
  echo
  echo "Expected format:"
  echo "   <ticket number>: <scope> - <short description>"
  echo
  echo "Accepted scopes:"
  echo "   feat - when a commit introduces a new feature to the codebase"
  echo "   refactor - modification of code that is neither a bug fix nor a new feature"
  echo "   fix - when a commit patches a bug in your codebase"
  echo "   chore - anything that doesn't affect the production code. (e.g., removing console logs)"
  echo "   docs - for documentation"
  echo "   build - changes that affect the build system or external dependencies"
  echo "   ci - changes to our CI configuration files and scripts"
  echo "   perf - a code change that improves performance"
  echo "   style - changes that do not affect the meaning of the code (e.g. formatting, missing semi-colons)"
  echo "   test - adding missing tests or correcting existing tests"
  echo "   revert - if the commit reverts a previous commit"
  echo
  exit 1
fi
